def test_byzantine_bounded_rejection():
    """T5: Byzantine injection → bounded rejection proven."""
    gsct = GSCT()
    # Byzantine: GAST still convergent, GCST still stable, but RCF drift spikes
    proof = gsct.evaluate(
        rcf_history=[{"t": i, "drift_score": 0.3, "convergence_score": 0.7} for i in range(3)]
               + [{"t": 3, "drift_score": 0.95, "convergence_score": 0.4}]  # spike
               + [{"t": 4, "drift_score": 0.3, "convergence_score": 0.7}],  # recovers
        gcst_history=[{"t": i, "stability_score": 0.85, "coherent": True} for i in range(5)],
        gast_report={"regime": "CONVERGENT", "attractor_exists": True},
        branch_graph={"b1": {"entropy": 0.5}},
        system_invariants={"GCST_coherence": True, "RCF_bounded": False},  # RCF violated
    )
    # System not closed because RCF unbounded at spike
    assert not proof.is_closed_system, "T5 FAIL: Byzantine should break closure"
    assert any("RCF" in f or "envelope" in f for f in proof.failure_modes), f"T5 FAIL: {proof.failure_modes}"
    print("  T5 byzantine_bounded_rejection: ✅")
    return True


