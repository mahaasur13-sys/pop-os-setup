def test_perfect_convergence():
    """T7: Perfect convergence → single attractor class."""
    gsct = GSCT()
    proof = gsct.evaluate(
        rcf_history=[{"t": i, "drift_score": 0.01, "convergence_score": 0.99} for i in range(5)],
        gcst_history=[{"t": i, "stability_score": 0.98, "coherent": True} for i in range(5)],
        gast_report={"regime": "CONVERGENT", "attractor_exists": True, "attractor_count": 1},
        branch_graph={"b1": {"entropy": 0.1}},
        system_invariants={"GCST_coherence": True, "RCF_bounded": True, "GAST_attractor": True},
    )
    assert proof.is_closed_system, f"T7 FAIL: {proof.failure_modes}"
    assert proof.global_convergence, "T7 FAIL: no convergence"
    assert proof.termination_guarantee, "T7 FAIL: no termination guarantee"
    assert len(proof.attractor_partition) == 1, f"T7 FAIL: {len(proof.attractor_partition)} attractors"
    print("  T7 perfect_convergence: ✅")
    return True


def run_tests():
    print("=== v11.4 GSCT Tests ===")
    results = []
    for name, fn in [
        ("T1 stable → closed", test_closed_stable),
        ("T2 oscillatory → partitioned", test_oscillatory_partitioned),
        ("T3 divergent → NOT closed", test_divergent_not_closed),
        ("T4 undefined → F4", test_undefined_fails),
        ("T5 byzantine → bounded rejection", test_byzantine_bounded_rejection),
        ("T6 multi-attractor → partition", test_multi_attractor_partition),
        ("T7 perfect → single attractor", test_perfect_convergence),
    ]:
        try:
            fn()
            results.append((name, True, ""))
        except AssertionError as e:
            results.append((name, False, str(e)))
        except Exception as e:
            results.append((name, False, f"ERROR: {e}"))

    passed = sum(1 for _, ok, _ in results if ok)
    total = len(results)
    print(f"\n{'='*50}")
    for name, ok, err in results:
        mark = "✅" if ok else "❌"
        print(f"  {mark} {name}: {'PASS' if ok else 'FAIL'}")
        if err:
            print(f"      {err}")
    print(f"{'='*50}")
    print(f"RESULT: {passed}/{total} passed")
    return passed == total


if __name__ == "__main__":
    ok = run_tests()
    sys.exit(0 if ok else 1)
