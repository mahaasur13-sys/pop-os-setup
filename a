from alignment.gsct import GSCT, Regime


def test_closed_stable():
    """T1: Fully stable system → CLOSED = TRUE."""
    gsct = GSCT()
    proof = gsct.evaluate(
        rcf_history=[{"t": i, "drift_score": 0.05, "convergence_score": 0.9} for i in range(5)],
        gcst_history=[{"t": i, "stability_score": 0.85, "coherent": True} for i in range(5)],
        gast_report={"regime": "CONVERGENT", "attractor_exists": True, "attractor_count": 1},
        branch_graph={"b1": {"entropy": 0.5}, "b2": {"entropy": 0.6}},
        system_invariants={"GCST_coherence": True, "RCF_bounded": True, "GAST_attractor": True},
    )
    assert proof.is_closed_system, f"T1 FAIL: {proof.failure_modes}"
    assert proof.global_convergence, f"T1 FAIL: no convergence"
    print("  T1 closed_stable: ✅")
    return True


