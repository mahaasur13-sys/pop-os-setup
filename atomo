from __future__ import annotations
import time, hashlib, asyncio
from dataclasses import dataclass, field
from typing import Dict, List, Optional

@dataclass
class Node:
    node_id: str
    last_heartbeat: float
    load: float = 0.0
    status: str = "ACTIVE"

@dataclass 
class DistributedControlPlane:
    def __init__(self, heartbeat_timeout: int = 10):
        self.nodes: Dict[str, Node] = {}
        self.heartbeat_timeout = heartbeat_timeout
        self.leader_id: Optional[str] = None
        self._recon = 0
        self._cnt = 0

    def register_node(self, node_id: str):
        self.nodes[node_id] = Node(node_id=node_id, last_heartbeat=time.time())

    def heartbeat(self, node_id: str):
        if node_id in self.nodes:
            self.nodes[node_id].last_heartbeat = time.time()
            self.nodes[node_id].status = "ACTIVE"

    def detect_failures(self):
        now = time.time()
        dead = []
        for n in self.nodes.values():
            if now - n.last_heartbeat > self.heartbeat_timeout:
                n.status = "DEAD"
                dead.append(n.node_id)
        return dead

    def elect_leader(self):
        active = [n for n in self.nodes.values() if n.status == "ACTIVE"]
        if not active:
            self.leader_id = None
            return None
        leader = max(active, key=lambda n: int(hashlib.md5(n.node_id.encode()).hexdigest()[:8], 16) - int(n.load * 100))
        self.leader_id = leader.node_id
        return self.leader_id

    def assign_task(self, task_id: Optional[str] = None) -> Optional[str]:
        active = [n for n in self.nodes.values() if n.status == "ACTIVE"]
        if not active:
            return None
        target = min(active, key=lambda n: n.load)
        tid = task_id or f"task-{self._cnt}"
        self._cnt += 1
        target.tasks.append(tid)
        target.load += 0.1
        return target.node_id

    def reconcile(self):
        self._recon += 1
        dead = self.detect_failures()
        self.elect_leader()
        return {"iteration": self._recon, "dead_nodes": dead, "leader": self.leader_id}

    def cluster_state(self) -> dict:
        return {
            "leader": self.leader_id,
            "nodes": {n.node_id: {"status": n.status, "load": round(n.load, 2), "tasks": len(n.tasks)} for n in self.nodes.values()},
        }

