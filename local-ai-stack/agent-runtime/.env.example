# ============================================================
# .env.example — agent-runtime Production Configuration
# ============================================================
# Copy to .env and adjust for your environment

# === Runtime ===
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:latest
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
OLLAMA_TIMEOUT=120

# === Redis ===
REDIS_URL=redis://redis:6379
REDIS_DB=0
REDIS_STREAM_KEY=agent:tasks
REDIS_RESULT_TTL=3600
REDIS_CONSUMER_GROUP=agent-workers
REDIS_CONSUMER_NAME=worker-1

# === Qdrant ===
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=agent_memory
QDRANT_VECTOR_SIZE=768
QDRANT_SCORE_THRESHOLD=0.7

# === API Server ===
API_HOST=0.0.0.0
API_PORT=8050
API_WORKERS=4
API_WORKER_CONCURRENCY=10
API_MAX_REQUEST_SIZE=10485760

# === Intelligence Layer ===
MODEL_ROUTING_ENABLED=true
TOOL_POLICY_ENABLED=true
MEMORY_FEEDBACK_ENABLED=true
EMBEDDING_CACHE_SIZE=1000
PATTERN_CACHE_SIZE=100

# === Cost Control ===
MAX_TOKENS_PER_TASK=8192
COST_BUDGET_PER_DAY=10.0
LATENCY_BUDGET_MS=30000

# === Observability ===
LOG_LEVEL=INFO
LOG_FORMAT=json
METRICS_ENABLED=true
METRICS_PORT=9090
SENTRY_DSN=
JAEGER_HOST=localhost
JAEGER_PORT=6831

# === Health ===
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=5
