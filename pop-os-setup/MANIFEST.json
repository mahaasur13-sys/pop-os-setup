{
  "version": "4.1",
  "schema": "2.0",
  "description": "pop-os-setup v4.1 — DAG Execution Contract",
  "engine": "dag-v4.1",
  "requires": ["bash@4", "jq", "sudo"],
  "state_version": "4.1",
  "profile_defaults": {
    "workstation": ["preflight", "update", "nvidia", "power", "kde", "dev-tools", "docker", "zsh", "neovim", "firewall", "python", "cron", "notifications", "backup", "final"],
    "ai-dev":    ["preflight", "update", "nvidia", "power", "kde", "dev-tools", "docker", "zsh", "neovim", "firewall", "python", "cuda", "ollama", "jupyter", "cron", "notifications", "backup", "final"],
    "cluster":   ["preflight", "update", "nvidia", "power", "dev-tools", "docker", "zsh", "firewall", "tailscale", "k8s", "storage", "monitoring", "backup", "final"],
    "full":      ["*"]
  },
  "stages": [
    {
      "id": "preflight",
      "name": "Pre-flight Checks",
      "stage_file": "stages/stage01_preflight.sh",
      "run_if": "true",
      "depends": [],
      "provides": ["network", "disk-space", "structure"],
      "version": "4.1",
      "verify": ["ip route show"]
    },
    {
      "id": "update",
      "name": "System Update",
      "stage_file": "stages/stage02_update.sh",
      "run_if": "true",
      "depends": ["preflight"],
      "provides": ["apt-updated"],
      "version": "1.0",
      "verify": ["apt list --upgradable 2>/dev/null | grep -c 'upgradable' || true"]
    },
    {
      "id": "nvidia",
      "name": "NVIDIA Driver",
      "stage_file": "stages/stage03_nvidia.sh",
      "run_if": "ENABLE_NVIDIA=1",
      "depends": ["preflight"],
      "provides": ["nvidia-driver", "cuda"],
      "version": "1.0",
      "verify": ["nvidia-smi"]
    },
    {
      "id": "power",
      "name": "Power Management",
      "stage_file": "stages/stage04_power.sh",
      "run_if": "ENABLE_POWER=1",
      "depends": ["preflight"],
      "provides": ["system76-power", "tlp"],
      "version": "1.0",
      "verify": ["system76-power --version || tlp-stat -v"]
    },
    {
      "id": "kde",
      "name": "KDE Plasma Desktop",
      "stage_file": "stages/stage05_kde.sh",
      "run_if": "ENABLE_KDE=1",
      "depends": ["preflight", "update"],
      "provides": ["kde-plasma", "sddm"],
      "version": "1.0",
      "verify": ["plasmashell --version"]
    },
    {
      "id": "dev-tools",
      "name": "Dev Toolchain",
      "stage_file": "stages/stage06_devtools.sh",
      "run_if": "true",
      "depends": ["preflight"],
      "provides": ["build-essential", "git", "curl", "python3"],
      "version": "1.0",
      "verify": ["gcc --version", "git --version", "python3 --version"]
    },
    {
      "id": "docker",
      "name": "Docker Runtime",
      "stage_file": "stages/stage07_docker.sh",
      "run_if": "ENABLE_DOCKER=1",
      "depends": ["dev-tools"],
      "provides": ["docker", "docker-compose"],
      "version": "4.1",
      "verify": ["docker ps", "docker compose version"]
    },
    {
      "id": "zsh",
      "name": "Zsh + Oh My Zsh",
      "stage_file": "stages/stage08_zsh.sh",
      "run_if": "ENABLE_ZSH=1",
      "depends": ["dev-tools"],
      "provides": ["zsh", "oh-my-zsh"],
      "version": "4.0",
      "verify": ["zsh --version"]
    },
    {
      "id": "neovim",
      "name": "Neovim IDE",
      "stage_file": "stages/stage09_neovim.sh",
      "run_if": "ENABLE_NEOVIM=1",
      "depends": ["dev-tools"],
      "provides": ["neovim"],
      "version": "4.0",
      "verify": ["nvim --version"]
    },
    {
      "id": "firewall",
      "name": "Firewall + Hardening",
      "stage_file": "stages/stage10_hardening.sh",
      "run_if": "ENABLE_HARDEN=1",
      "depends": ["preflight"],
      "provides": ["ufw", "fail2ban", "unattended-upgrades"],
      "version": "4.0",
      "verify": ["ufw status"]
    },
    {
      "id": "python",
      "name": "Python AI Stack",
      "stage_file": "stages/stage11_python.sh",
      "run_if": "ENABLE_PYTHON=1",
      "depends": ["dev-tools"],
      "provides": ["python3", "pip", "numpy", "jupyter"],
      "version": "1.0",
      "verify": ["python3 --version", "jupyter --version"]
    },
    {
      "id": "cuda",
      "name": "CUDA Toolkit",
      "stage_file": "stages/stage12_cuda.sh",
      "run_if": "ENABLE_CUDA=1",
      "depends": ["nvidia"],
      "provides": ["cuda-toolkit", "torch"],
      "version": "1.0",
      "verify": ["nvcc --version || nvidia-smi"]
    },
    {
      "id": "ollama",
      "name": "Ollama LLM",
      "stage_file": "stages/stage13_ollama.sh",
      "run_if": "ENABLE_OLLAMA=1",
      "depends": ["nvidia", "docker"],
      "provides": ["ollama"],
      "version": "1.0",
      "verify": ["curl -s http://localhost:11434/api/version || true"]
    },
    {
      "id": "k8s",
      "name": "k3s Kubernetes",
      "stage_file": "stages/stage14_k8s.sh",
      "run_if": "ENABLE_K8S=1",
      "depends": ["docker"],
      "provides": ["k3s", "kubectl", "helm"],
      "version": "1.0",
      "verify": ["kubectl version --client --short"]
    },
    {
      "id": "tailscale",
      "name": "Tailscale VPN",
      "stage_file": "stages/stage15_tailscale.sh",
      "run_if": "ENABLE_TAILSCALE=1",
      "depends": ["firewall"],
      "provides": ["tailscale"],
      "version": "4.0",
      "verify": ["tailscale status --self"]
    },
    {
      "id": "ssh-gpg",
      "name": "SSH + GPG",
      "stage_file": "stages/stage16_ssh_gpg.sh",
      "run_if": "ENABLE_SSH=1",
      "depends": ["dev-tools"],
      "provides": ["ssh-keys", "gpg"],
      "version": "4.0",
      "verify": ["ls ~/.ssh/id_ed25519.pub"]
    },
    {
      "id": "cron",
      "name": "Cron Jobs",
      "stage_file": "stages/stage17_cron.sh",
      "run_if": "ENABLE_CRON=1",
      "depends": ["dev-tools"],
      "provides": ["cron-jobs"],
      "version": "4.0",
      "verify": ["crontab -l"]
    },
    {
      "id": "notifications",
      "name": "Notifications",
      "stage_file": "stages/stage18_notifications.sh",
      "run_if": "ENABLE_NOTIFICATIONS=1",
      "depends": ["cron"],
      "provides": ["systemd-user-timers"],
      "version": "4.0",
      "verify": ["systemctl --user list-timers --all"]
    },
    {
      "id": "backup",
      "name": "Backup System",
      "stage_file": "stages/stage19_backup.sh",
      "run_if": "ENABLE_BACKUP=1",
      "depends": ["docker", "cron"],
      "provides": ["backup-utility"],
      "version": "4.0",
      "verify": ["ls /var/lib/pop-os-setup/backups/ 2>/dev/null || echo 'backup dir ready'"]
    },
    {
      "id": "final",
      "name": "Final Verification",
      "stage_file": "stages/stage20_final.sh",
      "run_if": "true",
      "depends": ["zsh", "docker", "firewall"],
      "provides": ["system-ready"],
      "version": "4.0",
      "verify": ["echo 'all systems nominal'"]
    }
  ],
  "provides_index": {
    "docker": "stage07",
    "docker-compose": "stage07",
    "zsh": "stage08",
    "neovim": "stage09",
    "kde-plasma": "stage05",
    "nvidia-driver": "stage03",
    "k3s": "stage14",
    "tailscale": "stage15",
    "firewall": "stage10"
  }
}
