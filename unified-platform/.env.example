# ==============================================================================
# ACOS — ML Inference API Environment Variables
# COPY THIS FILE TO: .env
# ==============================================================================

ML_API_HOST=0.0.0.0
ML_API_PORT=8081
ML_MODEL_PATH=ml_engine/models/failure_xgb_v2.pkl
ML_API_WORKERS=4
ML_CACHE_TTL_SECONDS=5

LOG_LEVEL=INFO
LOG_FORMAT=json

TSDB_HOST=10.30.30.10
TSDB_PORT=5432
TSDB_USER=postgres
TSDB_PASSWORD=CHANGE_ME
TSDB_NAME=acos_features

SLURM_CONF=/etc/slurm/slurm.conf
SLURM_CLUSTER_NAME=home-gpu-cluster

RAY_HEAD_ADDRESS=10.20.20.10:6379
RAY_DASHBOARD_URL=http://10.20.20.10:8265

CEPH_MON_HOST=10.30.30.10:6789
CEPHFS_MON_HOST=10.30.30.10
CEPHFS_MOUNT=/mnt/ceph-storage

API_RATE_LIMIT=100
API_KEY_REQUIRED=false
