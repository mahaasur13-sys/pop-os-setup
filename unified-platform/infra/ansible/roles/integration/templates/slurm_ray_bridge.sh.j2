#!/bin/bash
# ============================================================
# Slurm → Ray bridge script
# Auto-generated by Ansible (Day 7 integration)
# ============================================================

RAY_HEAD="{{ hostvars[groups['ray_head'][0]]['ansible_host'] if groups.get('ray_head') else 'localhost' }}"
SLURM_HEAD="{{ hostvars[groups['slurm_controller'][0]]['ansible_host'] if groups.get('slurm_controller') else 'localhost' }}"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
}

# Check Ray cluster availability
check_ray() {
    ray status --address="http://${RAY_HEAD}:8265" >/dev/null 2>&1
    return $?
}

# Check Slurm availability
check_slurm() {
    sinfo >/dev/null 2>&1
    return $?
}

# Route job to appropriate backend
route_job() {
    local job_file="$1"
    local job_type="$2"  # "ray" or "slurm"

    if [[ "$job_type" == "ray" ]]; then
        log "Routing job to Ray: $job_file"
        if check_ray; then
            ray submit --address="http://${RAY_HEAD}:8265" "$job_file"
        else
            log "ERROR: Ray cluster unavailable, falling back to Slurm"
            sbatch "$job_file"
        fi
    else
        log "Routing job to Slurm: $job_file"
        sbatch "$job_file"
    fi
}

# Usage
if [[ $# -lt 2 ]]; then
    echo "Usage: $0 <job_file> <ray|slurm>"
    exit 1
fi

route_job "$1" "$2"
