# Prometheus config — auto-generated by Terraform/Ansible
global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:9090"]

  - job_name: "node_exporter"
    static_configs:
      - targets:
{% for host in groups['all'] %}
        - "{{ hostvars[host]['ansible_host'] | default(host) }}:9100"
{% endfor %}

  - job_name: "slurm"
    static_configs:
      - targets:
{% for host in groups.get('slurm_controller', []) %}
        - "{{ hostvars[host]['ansible_host'] | default(host) }}:8080"
{% endfor %}

  - job_name: "ray"
    static_configs:
      - targets:
{% for host in groups.get('ray_head', []) %}
        - "{{ hostvars[host]['ansible_host'] | default(host) }}:8265"
{% endfor %}

  - job_name: "ceph"
    static_configs:
      - targets:
{% for host in groups.get('ceph_mon', []) %}
        - "{{ hostvars[host]['ansible_host'] | default(host) }}:9283"
{% endfor %}
