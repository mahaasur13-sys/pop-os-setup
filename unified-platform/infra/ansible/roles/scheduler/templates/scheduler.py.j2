#!/usr/bin/env python3
"""
AI Scheduler — FastAPI service
Routes jobs to optimal nodes based on real-time load
"""
import subprocess
import psutil
import json
from typing import Optional
from fastapi import FastAPI, HTTPException
from pydantic import BaseModel

app = FastAPI(title="AI Scheduler")

GPU_NODE_IP = "{{ hostvars[groups['rtx_node'][0]].ansible_host | default('10.20.20.10') }}"
CPU_NODE_IP = "{{ hostvars[groups['rk3576_node'][0]].ansible_host | default('10.20.20.20') }}"
GPU_NODE_NAME = "rtx-node"
CPU_NODE_NAME = "rk3576-node"
VPS_NODE_NAME = "vps-node"
VPS_NODE_IP = "10.40.40.30"

SLURM_THRESHOLD_GPU = 70   # % GPU util — above this, queue jobs
SLURM_THRESHOLD_CPU = 80   # % CPU util — above this, queue jobs
MEMORY_THRESHOLD = 80      # % RAM — above this, use other node

class ScheduleRequest(BaseModel):
    job_type: str = "gpu"        # "gpu" | "cpu" | "arm" | "any"
    memory_gb: Optional[int] = None
    priority: Optional[int] = 5
    job_name: Optional[str] = "unnamed"

class ScheduleResponse(BaseModel):
    target: str
    target_ip: str
    partition: str
    reason: str
    queue_position: Optional[int] = None

def get_gpu_load() -> int:
    """Get current GPU utilization %"""
    try:
        out = subprocess.check_output(
            ["nvidia-smi", "--query-gpu=utilization.gpu",
             "--format=csv,noheader,nounits"],
            text=True
        )
        return int(out.strip().split('\n')[0])
    except Exception:
        return 100  # treat as maxed out if unavailable

def get_node_load(ip: str) -> dict:
    """Ping node and get basic load info"""
    try:
        result = subprocess.run(
            ["ping", "-c", "1", "-W", "1", ip],
            capture_output=True, text=True
        )
        reachable = result.returncode == 0
    except Exception:
        reachable = False

    return {
        "ip": ip,
        "reachable": reachable,
        "cpu_percent": psutil.cpu_percent(interval=0.1),
        "memory_percent": psutil.virtual_memory().percent,
    }

def score_node(node_type: str, gpu_load: int, cpu_load: float,
               mem_percent: float, reachable: bool) -> float:
    """Score node fitness for job — higher is better"""
    if not reachable:
        return 0.0

    if node_type == "gpu":
        score = 100 - gpu_load
        score -= (mem_percent / 5)
        if gpu_load > 90:
            score -= 50
    elif node_type == "cpu":
        score = 100 - cpu_load
        score -= (mem_percent / 5)
        if cpu_load > 90:
            score -= 50
    elif node_type == "arm":
        score = 80 - cpu_load
    else:
        score = 50

    return max(0.0, score)

@app.get("/health")
def health():
    return {"status": "ok", "service": "ai-scheduler"}

@app.get("/nodes")
def list_nodes():
    """Return status of all known nodes"""
    gpu_load = get_gpu_load()
    rtx_status = get_node_load(GPU_NODE_IP)
    rk_status = get_node_load(CPU_NODE_IP)
    vps_status = get_node_load(VPS_NODE_IP)

    return {
        "nodes": [
            {
                "name": GPU_NODE_NAME,
                "type": "gpu",
                "ip": GPU_NODE_IP,
                "reachable": rtx_status["reachable"],
                "gpu_load": gpu_load,
                "cpu_load": rtx_status["cpu_percent"],
                "memory_percent": rtx_status["memory_percent"],
            },
            {
                "name": CPU_NODE_NAME,
                "type": "cpu",
                "ip": CPU_NODE_IP,
                "reachable": rk_status["reachable"],
                "cpu_load": rk_status["cpu_percent"],
                "memory_percent": rk_status["memory_percent"],
            },
            {
                "name": VPS_NODE_NAME,
                "type": "cloud",
                "ip": VPS_NODE_IP,
                "reachable": vps_status["reachable"],
                "cpu_load": vps_status["cpu_percent"],
            },
        ],
        "global_gpu_load": gpu_load,
    }

@app.post("/schedule", response_model=ScheduleResponse)
def schedule_job(req: ScheduleRequest):
    """
    Main scheduling endpoint.
    Routes job to best available node or queues it.
    """
    gpu_load = get_gpu_load()

    if req.job_type == "gpu":
        if gpu_load < SLURM_THRESHOLD_GPU:
            return ScheduleResponse(
                target=GPU_NODE_NAME,
                target_ip=GPU_NODE_IP,
                partition="gpu",
                reason=f"GPU load {gpu_load}% < {SLURM_THRESHOLD_GPU}%, direct GPU execution"
            )
        else:
            return ScheduleResponse(
                target="QUEUE",
                target_ip="queued",
                partition="gpu",
                reason=f"GPU load {gpu_load}% >= {SLURM_THRESHOLD_GPU}%, queued",
                queue_position=1
            )

    elif req.job_type == "cpu":
        rk_reachable = get_node_load(CPU_NODE_IP)["reachable"]
        if rk_reachable:
            return ScheduleResponse(
                target=CPU_NODE_NAME,
                target_ip=CPU_NODE_IP,
                partition="cpu",
                reason="RK3576 edge node available"
            )
        else:
            return ScheduleResponse(
                target="QUEUE",
                target_ip="queued",
                partition="cpu",
                reason="No reachable CPU nodes",
                queue_position=1
            )

    elif req.job_type == "arm":
        return ScheduleResponse(
            target=CPU_NODE_NAME,
            target_ip=CPU_NODE_IP,
            partition="arm",
            reason="RK3576 ARM node selected for ARM workload"
        )

    else:
        return ScheduleResponse(
            target=GPU_NODE_NAME,
            target_ip=GPU_NODE_IP,
            partition="gpu",
            reason="Default: GPU node"
        )

if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8080)
