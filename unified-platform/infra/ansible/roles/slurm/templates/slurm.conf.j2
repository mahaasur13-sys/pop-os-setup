# ============================================================
# Slurm config — Controller ({{ inventory_hostname }})
# Generated by: home-cluster-iac ansible/roles/slurm
# ============================================================

ClusterName={{ slurm_cluster_name | default("home-cluster") }}
ControlMachine={{ ansible_host }}
ControlAddr={{ ansible_host }}
SlurmUser=slurm

# — Paths —
SlurmctldPort=6817
SlurmdPort=6818
StateSaveLocation=/var/spool/slurmctld
SlurmdSpoolDir=/var/spool/slurmd
SwitchType=SwitchType/NONE
MungeDefaultFileKey=yes

# — Scheduling —
SchedulerType=sched/backfill
SelectType=SelectType_4
SelectTypeParameters=CR_CPU_Memory,CR_CPU

# — GPUs —
GresTypes=gpu

# — Partitions —
NodeName={{ ansible_host }} RealMemory={{ ansible_memory_real | default(64000) }} State=UNKNOWN
NodeName={{ hostvars[groups['slurm_compute'][1] | default('edge')]['ansible_host'] | default('192.168.20.11') }} RealMemory={{ hostvars[groups['slurm_compute'][1] | default('edge')]['ansible_memory_real'] | default(16000) }} State=UNKNOWN

PartitionName=gpu Nodes={{ groups['slurm_compute'] | join(',') }} Default=YES MaxTime=1440 State=UP
# gres.conf sets GPU gres per node
