# keepalived.conf.j2 — HA VIP for Slurm controllers
# Virtual IP: {{ keepalived_vip }}
# This node priority: {% if inventory_hostname == slurm_control_machines[0] %}{{ keepalived_priority_primary }}{% elif slurm_control_machines[1] is defined %}{{ keepalived_priority_secondary }}{% else %}{{ keepalived_priority_tertiary }}{% endif %}

global_defs {
    router_id slurm_ha
    vrrp_ignore_ttl_assert
}

vrrp_instance VI_SLURM {
    interface {{ keepalived_interface }}
    virtual_router_id 51
    priority {% if inventory_hostname == slurm_control_machines[0] %}{{ keepalived_priority_primary }}{% elif slurm_control_machines[1] is defined %}{{ keepalived_priority_secondary }}{% else %}{{ keepalived_priority_tertiary }}{% endif %}
    advert_int 2
    nopreempt

    virtual_ipaddress {
        {{ keepalived_vip }}/24 dev {{ keepalived_interface }}
    }

    track_script {
        chk_slurmctld
    }

    notify_master "/usr/local/bin/slurm_ha_notify.sh master"
    notify_backup "/usr/local/bin/slurm_ha_notify.sh backup"
    notify_fault  "/usr/local/bin/slurm_ha_notify.sh fault"
}

vrrp_script chk_slurmctld {
    script "/usr/bin/pgrep -x slurmctld"
    interval 3
    weight -10
    fall 2
    rise 1
}
