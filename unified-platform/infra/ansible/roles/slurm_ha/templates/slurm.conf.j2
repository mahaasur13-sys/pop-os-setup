# slurm.conf.j2 — HA Slurm configuration
# Generated by Ansible for {{ slurm_cluster_name }}
# Controllers: {{ slurm_control_machines | join(', ') }}

ClusterName={{ slurm_cluster_name }}

# ── Control Machines (all HA controllers) ──────────────────────────────────
{% for ctrl in slurm_control_machines %}
SlurmctldHost={{ ctrl }}{% if loop.first %}*{{ else }}{% endif %}
{% endfor %}

# State location on CephFS (shared)
StateSaveLocation={{ slurm_state_dir }}
SlurmdSpoolDir={{ slurm_spool_dir }}/slurmd
TaskPlugin=cgroup,cpu
ProctrackType=cgroup

# ── Scheduling ───────────────────────────────────────────────────────────────
SchedulerType=sched/backfill
SelectType=select/cons_tres
SelectTypeParameters=CR_CPU_Memory,CR_GPU

# ── Logging ──────────────────────────────────────────────────────────────────
SlurmctldDebug=info
SlurmctldLogFile={{ slurm_log_dir }}/slurmctld.log
SlurmdDebug=info
SlurmdLogFile={{ slurm_log_dir }}/slurmd.log

# ── Authentication ─────────────────────────────────────────────────────────
MungeAuthentication=1

# ── Database (if enabled) ───────────────────────────────────────────────────
{% if slurm_enable_db | bool %}
AccountingStorageType=accounting_storage/slurmdbd
AccountingStorageHost={{ slurm_db_host }}
AccountingStoragePort={{ slurm_db_port }}
AccountingStorageEnforce= associations
SlurmDBDAddr={{ slurm_db_host }}
SlurmDBDPort={{ slurm_db_port | default(6819) }}
{% endif %}

# ── Partitions ─────────────────────────────────────────────────────────────
{% for partition in slurm_partitions %}
PartitionName={{ partition.name }}
{% if partition.default | default(false) %}Default=Yes{% endif %}
Nodes={{ partition.nodes | join(',') }}
MaxTime={{ partition.max_time | default('INFINITE') }}
State=UP
{% endfor %}
